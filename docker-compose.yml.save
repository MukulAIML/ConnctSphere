      - SPRING_DATASOURCE_URL=jdbc:mysql://connectsphere-db:3306/notification_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
      - SPRING_DATASOURCE_USERNAME=mukul
