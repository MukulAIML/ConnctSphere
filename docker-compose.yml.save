      - SPRING_APPLICATION_NAME=media-service
      - SPRING_DATASOURCE_URL=jdbc:mysql://connectsphere-db:3306/media_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
      - SPRING_DATASOURCE_USERNAME=mukul
