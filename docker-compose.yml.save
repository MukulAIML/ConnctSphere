version: '3.8'

services:
  connectsphere-db:
    image: mysql:8.0
    command: --default-authentication-plugin=mysql_native_password --innodb-buffer-pool-size=64M
    container_name: connectsphere-db
    ports:
      - "3306:3306"
    # 🛡️ THE ARCHITECTURAL GUARANTEE: Force MySQL to use native password plugin at server level.
    # This prevents ANY user from being created with caching_sha2_password.
    command: --default-authentication-plugin=mysql_native_password
    environment:
      - JAVA_TOOL_OPTIONS=-Xms64m -Xmx128m
      - SPRING_MAIN_LAZY_INITIALIZATION=true
      - SPRING_JPA_OPEN_IN_VIEW=false
      MYSQL_ROOT_PASSWORD: root
      # Note: We do NOT use MYSQL_USER here to ensure our init.sql handles creation deterministically.
    volumes:
      - ./docker-config/init-db.sql:/docker-entrypoint-initdb.d/init-db.sql
      - mysql_data:/var/lib/mysql
    networks:
      - connectsphere-network
    healthcheck:
      test: ["CMD", "










mysqladmin", "ping", "-h", "localhost", "-u", "root", "-proot"]
      interval: 10s
      timeout: 5s
      retries: 5

  service-registry:
    build: ./service-registry
    mem_limit: 256m
    container_name: service-registry
    ports:
      - "8761:8761"
    networks:
      - connectsphere-network

  api-gateway:
    build: ./api-gateway
    mem_limit: 256m
    container_name: api-gateway
    ports:
      - "9000:9000"
    environment:
      - JAVA_TOOL_OPTIONS=-Xms64m -Xmx128m
      - SPRING_MAIN_LAZY_INITIALIZATION=true
      - SPRING_JPA_OPEN_IN_VIEW=false
      - EUREKA_SERVER=http://service-registry:8761/eureka/
    depends_on:
      - service-registry
    networks:
      - connectsphere-network

  auth-service:
    build: ./auth-service
    mem_limit: 256m
    container_name: auth-service
    environment:
      - JAVA_TOOL_OPTIONS=-Xms64m -Xmx128m
      - SPRING_MAIN_LAZY_INITIALIZATION=true
      - SPRING_JPA_OPEN_IN_VIEW=false
      - SPRING_APPLICATION_NAME=auth-service
      - SPRING_DATASOURCE_URL=jdbc:mysql://connectsphere-db:3306/connectsphere_auth?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
      - SPRING_DATASOURCE_USERNAME=mukul
      - SPRING_DATASOURCE_PASSWORD=password
      - SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect
      - LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_JDBC=DEBUG
      - JWT_SECRET=ConnectSphereSecretKey2026ConnectSphereSecretKey2026ConnectSphereSecretKey
      - EUREKA_SERVER=http://service-registry:8761/eureka/
    depends_on:
      connectsphere-db:
        condition: service_healthy
      service-registry:
        condition: service_started
    networks:
      - connectsphere-network

  post-service:
    build: ./post-service
    mem_limit: 256m
    container_name: post-service
    environment:
      - JAVA_TOOL_OPTIONS=-Xms64m -Xmx128m
      - SPRING_MAIN_LAZY_INITIALIZATION=true
      - SPRING_JPA_OPEN_IN_VIEW=false
      - SPRING_APPLICATION_NAME=post-service
      - SPRING_DATASOURCE_URL=jdbc:mysql://connectsphere-db:3306/post_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
      - SPRING_DATASOURCE_USERNAME=mukul
      - SPRING_DATASOURCE_PASSWORD=password
      - SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect
      - LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_JDBC=DEBUG
      - JWT_SECRET=ConnectSphereSecretKey2026ConnectSphereSecretKey2026ConnectSphereSecretKey
      - SEARCH_SERVICE_URL=http://search-service:8087
      - EUREKA_SERVER=http://service-registry:8761/eureka/
    depends_on:
      connectsphere-db:
        condition: service_healthy
      service-registry:
        condition: service_started
    networks:
      - connectsphere-network

  comment-service:
    build: ./comment-service
    mem_limit: 256m
    container_name: comment-service
    environment:
      - JAVA_TOOL_OPTIONS=-Xms64m -Xmx128m
      - SPRING_MAIN_LAZY_INITIALIZATION=true
      - SPRING_JPA_OPEN_IN_VIEW=false
      - SPRING_APPLICATION_NAME=comment-service
      - SPRING_DATASOURCE_URL=jdbc:mysql://connectsphere-db:3306/comment_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
      - SPRING_DATASOURCE_USERNAME=mukul
      - SPRING_DATASOURCE_PASSWORD=password
      - SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect
      - LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_JDBC=DEBUG
      - JWT_SECRET=ConnectSphereSecretKey2026ConnectSphereSecretKey2026ConnectSphereSecretKey
      - POST_SERVICE_URL=http://post-service:8081
      - NOTIFICATION_SERVICE_URL=http://notification-service:8085
      - EUREKA_SERVER=http://service-registry:8761/eureka/
    depends_on:
      connectsphere-db:
        condition: service_healthy
      service-registry:
